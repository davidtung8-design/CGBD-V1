rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSupervisor() {
      return isSignedIn() && 
             request.auth.token.email == "Davidtung8@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUserPerf(data) {
      return data.get('personalQ', 0) is number
          && data.get('teamQ', 0) is number
          && data.get('wishingStatement', '').size() <= 1000
          && data.get('milestones', []).size() <= 50;
    }

    function isValidCalendarEvent(data) {
      return data.title is string && data.title.size() <= 200
          && data.startHour is number && data.startHour >= 0 && data.startHour <= 24
          && data.endHour is number && data.endHour >= 0 && data.endHour <= 24
          && data.weekday is number && data.weekday >= 0 && data.weekday <= 6
          && data.weekOffset is number
          && data.activityId is number;
    }

    function isValidDailyTodo(data) {
      return data.items is list && data.items.size() <= 100;
    }

    function isValidDailyRecord(data) {
      return data.r is string && data.r.size() <= 5000
          && data.g is string && data.g.size() <= 5000
          && data.get('sixTasks', []).size() <= 6
          && data.get('protocol5352111', []).size() <= 50;
    }

    // --- Rules ---

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSupervisor();
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isSupervisor();
      }
    }
  }
}
